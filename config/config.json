{
  "api": {
    "token_file": "data/anthropic-token.txt",
    "base_url": "https://api.anthropic.com",
    "default_model": "claude-sonnet-4-20250514",
    "max_tokens": 8192,
    "timeout_ms": 120000
  },
  "daemon": {
    "socket_path": "data/clawforge.sock",
    "data_dir": "data",
    "log_level": "info",
    "max_clients": 5
  },
  "tools": {
    "enabled": ["bash", "file_read", "file_write", "file_diff", "amazon_search", "calc", "introspect", "meme_tool", "rebuild", "zig_test", "research_tool", "summon_subagent", "discord_history"],
    "bash_require_confirmation": true,
    "bash_timeout_ms": 30000,
    "file_write_require_confirmation": true
  },
  "display": {
    "stream_output": true,
    "show_tool_calls": true,
    "show_token_usage": true,
    "color_output": true
  },
  "discord": {
    "enabled": true,
    "token_file": "",
    "guild_id": "",
    "channel_id": ""
  },
  "ollama": {
    "enabled": true,
    "base_url": "http://127.0.0.1:11434",
    "default_model": "qwen3:4b",
    "num_ctx": 49152
  },
  "openrouter": {
    "enabled": true,
    "default_model": "x-ai/grok-4.1-fast"
  },
  "vision": {
    "enabled": true,
    "model": "claude-haiku-4-5-20251001",
    "max_image_bytes": 10485760,
    "max_images_per_turn": 2,
    "max_output_tokens": 512,
    "prompt": "Describe this image in detail. Extract any visible text verbatim (OCR). If it shows an error, UI, diagram, or code, extract the relevant structure. Be concise and factual — no speculation."
  }
}
