=== 5. Message Store Integration ===

Add to MessageStore interface (src/storage/message.zig), if addSystemMessage doesn't exist:
```zig
    pub fn addSystemMessage(self: *MessageStore, session_id: []const u8, content: []const u8) !i64 {
        const stmt = try self.db.prepare(
            \\INSERT INTO messages (session_id, role, content, metadata) 
            \\VALUES (?1, 'system', ?2, '{}') RETURNING id
        );
        defer stmt.deinit();

        stmt.bind(1, session_id) catch unreachable;
        stmt.bind(2, content) catch unreachable;

        if (stmt.step() catch return error.DatabaseError) {
            return stmt.columnInt64(0);
        }
        return error.InsertFailed;
    }
```

