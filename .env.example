# ClawForge Environment Variables
# Copy to .env and fill in values. The .env file is gitignored.

# ---- Paths ----
# Override project root (defaults: derived from binary location).
# CLAWFORGE_ROOT=/path/to/ClawForge

# Python interpreter used for tool scripts. If unset, falls back to
# "python3" on PATH. Point this at a venv with required deps
# (playwright, ollama client, etc.).
# CLAWFORGE_PYTHON=/path/to/venv/bin/python3

# Override DB path (default: $CLAWFORGE_ROOT/data/workspace.db).
# CLAWFORGE_DB=/path/to/workspace.db

# Extra Python path(s) — colon-separated, added to sys.path for tools
# that import user-maintained helpers (e.g. browser_fetch).
# CLAWFORGE_EXTRA_PYPATH=/path/to/shared/pylibs

# External rebuild script used by the `rebuild` tool. If unset, falls
# back to $HOME/.local/bin/clawforge-rebuild.sh.
# CLAWFORGE_REBUILD_SCRIPT=/path/to/clawforge-rebuild.sh

# Path to test daemon binary (used by tests/test_webui.py).
# CLAWFORGE_DAEMON=/path/to/zig-out/bin/clawforged

# ---- Secrets ----
# Imgflip API (for meme generation)
IMGFLIP_USERNAME=
IMGFLIP_PASSWORD=

# OpenRouter API
OPENROUTER_API_KEY=

# Discord bot
DISCORD_TOKEN=

# Optional: override default fast model
# FAST_MODEL=x-ai/grok-4.1-fast
