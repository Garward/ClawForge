const std = @import("std");
const common = @import("common");
const api = @import("api");
const tools = @import("tools");
const storage = @import("storage");
const core = @import("core");
const workers = @import("workers");
const adapters = @import("adapters");

pub fn main() !void {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    // Load configuration
    var config = try common.Config.load(allocator, null);
    defer config.deinit();

    // Get socket path
    const socket_path = try common.config.getSocketPath(allocator, &config);
    defer allocator.free(socket_path);

    std.log.info("ClawForge Daemon starting...", .{});

    // Resolve auth profiles path and load
    const auth_profiles_path = try common.config.resolveProjectPath(allocator, config.auth.profiles_path);
    defer allocator.free(auth_profiles_path);

    var auth_store = common.AuthProfileStore.load(allocator, auth_profiles_path) catch |err| blk: {
        std.log.warn("Failed to load auth profiles: {}, starting fresh", .{err});
        break :blk common.AuthProfileStore.init(allocator);
    };
    defer auth_store.deinit();

    // Initialize API client
    var api_client = blk: {
        if (auth_store.getActiveCredential("anthropic")) |profile| {
            std.log.info("Using auth profile: {s}", .{profile.id});
            break :blk api.AnthropicClient.initWithCredential(allocator, &config, profile.credential);
        } else {
            std.log.info("No eligible auth profile, loading from token file", .{});
            break :blk try api.AnthropicClient.init(allocator, &config);
        }
    };
    defer api_client.deinit();
    std.log.info("API client initialized", .{});

    // Initialize tool registry
    var tool_registry = tools.ToolRegistry.init(allocator);
    defer tool_registry.deinit();
    try tool_registry.registerDefaults();
    for (config.tools.enabled) |tool_name| {
        tool_registry.enable(tool_name) catch {};
    }
    std.log.info("Tools registered", .{});

    // Resolve data directory path
    const data_dir = try common.config.resolveProjectPath(allocator, config.daemon.data_dir);
    defer allocator.free(data_dir);

    // Initialize SQLite database
    var database = try storage.Database.init(allocator, data_dir);
    defer database.deinit();
    try storage.runMigrations(&database.conn);
    std.log.info("Database initialized", .{});

    // Set up default namespace
    var ns = storage.Namespaces.init(&database.conn);
    const cli_ns_id = try ns.ensurePath("default/cli");

    // Initialize stores
    var session_store = storage.SessionStore.init(&database.conn, allocator, cli_ns_id, config.api.default_model);
    var message_store = storage.MessageStore.init(&database.conn, allocator);
    var project_store = storage.ProjectStore.init(&database.conn, allocator, cli_ns_id);
    var summary_store = storage.SummaryStore.init(&database.conn, allocator, cli_ns_id);

    // Initialize summarizer with its own DB connection for thread safety
    const summarizer_conn = try database.openConnection();
    var summarizer_msg_store = storage.MessageStore.init(summarizer_conn, allocator);
    var summarizer_sum_store = storage.SummaryStore.init(summarizer_conn, allocator, cli_ns_id);
    var summarizer_proj_store = storage.ProjectStore.init(summarizer_conn, allocator, cli_ns_id);
    var summarizer_worker = workers.Summarizer.init(
        allocator,
        &api_client,
        &summarizer_msg_store,
        &summarizer_sum_store,
        &summarizer_proj_store,
    );

    // ================================================================
    // PROVIDER SYSTEM — configurable tier-to-provider mapping
    // ================================================================

    // Wrap Anthropic client as a Provider
    const anthropic_prov = api.anthropic_provider.asProvider(&api_client);

    // Create provider registry
    var provider_registry = api.ProviderRegistry.init(allocator);
    defer provider_registry.deinit();
    provider_registry.register("anthropic", anthropic_prov) catch {};

    // Create Ollama provider if enabled
    var ollama_client: ?api.OllamaClient = null;
    if (config.ollama.enabled) {
        ollama_client = api.OllamaClient.init(allocator, config.ollama.base_url, config.ollama.default_model);
        provider_registry.register("ollama", ollama_client.?.provider()) catch {};
        std.log.info("Ollama provider registered ({s})", .{config.ollama.base_url});
    }

    // Create OpenAI provider if enabled
    var openai_client: ?api.OpenAIClient = null;
    if (config.openai.enabled) {
        // Load API key from file
        const openai_key = common.config.loadApiKey(allocator, config.openai.api_key_file) catch "";
        openai_client = api.OpenAIClient.init(allocator, openai_key, config.openai.base_url, config.openai.default_model);
        provider_registry.register("openai", openai_client.?.provider()) catch {};
        std.log.info("OpenAI provider registered ({s})", .{config.openai.base_url});
    }
    defer if (openai_client) |*oc| oc.deinit();

    // Map tiers to providers from config
    provider_registry.mapTier("fast", config.routing.fast_provider) catch {};
    provider_registry.mapTier("default", config.routing.default_provider) catch {};
    provider_registry.mapTier("smart", config.routing.smart_provider) catch {};
    std.log.info("Provider tiers: fast={s} default={s} smart={s}", .{
        config.routing.fast_provider,
        config.routing.default_provider,
        config.routing.smart_provider,
    });

    // Default provider = whatever "default" tier maps to
    const default_provider = provider_registry.getForTier("default") orelse anthropic_prov;

    // Initialize the core engine (shared by all adapters)
    var engine = core.Engine.init(
        allocator,
        &config,
        default_provider,
        &session_store,
        &message_store,
        &project_store,
        &tool_registry,
        &auth_store,
        auth_profiles_path,
    );

    // Initialize extractor with its own DB connection for thread safety
    const extractor_conn = try database.openConnection();
    var knowledge_store = storage.KnowledgeStore.init(extractor_conn, allocator, cli_ns_id);
    var extractor_sum_store = storage.SummaryStore.init(extractor_conn, allocator, cli_ns_id);
    var extractor_worker = workers.Extractor.init(
        allocator,
        &api_client,
        &extractor_sum_store,
        &knowledge_store,
    );

    // Initialize embedder with its own DB connection for thread safety
    const embedder_conn = try database.openConnection();
    var embedding_store = storage.EmbeddingStore.init(embedder_conn, allocator, cli_ns_id);
    var embedder_worker = workers.Embedder.init(allocator, &embedding_store);
    // Hybrid search uses the main connection (reads only, on main/adapter threads)
    var hybrid_search_inst = core.HybridSearch.init(allocator, &database.conn, &embedding_store, cli_ns_id);

    // Initialize tool generator (self-extension)
    var tool_gen = tools.ToolGenerator.init(
        allocator,
        default_provider,
        &database.conn,
        cli_ns_id,
        &tool_registry,
        data_dir,
    );
    // Load previously approved generated tools
    const loaded_tools = tool_gen.loadApprovedTools() catch 0;
    if (loaded_tools > 0) {
        std.log.info("Loaded {d} generated tools", .{loaded_tools});
    }

    // Wire provider registry to engine
    engine.setProviderRegistry(&provider_registry);

    // Wire all workers to engine (needs engine to exist first)
    engine.setSummarizer(&summarizer_worker, &summary_store);
    engine.setExtractor(&extractor_worker, &knowledge_store);
    engine.setSearch(&embedder_worker, &hybrid_search_inst);

    // Skills store — uses main DB connection (read-heavy, no worker needed)
    var skill_store = storage.SkillStore.init(&database.conn, allocator, cli_ns_id);
    engine.setSkillStore(&skill_store);

    // Create and start the worker pool (async background processing).
    // Each worker has its own DB connection — WAL mode handles concurrent reads,
    // SQLite serializes writes via busy_timeout.
    var worker_pool = workers.WorkerPool.init(
        allocator,
        &summarizer_worker,
        &extractor_worker,
        &embedder_worker,
    );
    engine.setWorkerPool(&worker_pool);
    worker_pool.start();
    engine.setToolGenerator(&tool_gen);

    // Optimization manager — file cache, result cache, batch processor, context pruner
    var opt_manager = core.optimization.OptimizationManager.init(allocator, &message_store);
    defer opt_manager.deinit();
    engine.setOptimizationManager(&opt_manager);
    std.log.info("Worker pool started (3 threads, per-thread DB connections)", .{});

    // ================================================================
    // ADAPTER SYSTEM — each adapter runs in its own thread
    // ================================================================

    // Ensure adapter registry table exists
    adapters.ensureRegistryTable(&database.conn);

    // CLI Socket Adapter (primary — runs on main thread)
    var cli = adapters.CliAdapter.init(allocator, &config, &engine, socket_path);
    defer cli.deinit();
    const cli_adapter = cli.adapter();
    try cli_adapter.start();
    adapters.registerAdapter(&database.conn, cli_adapter);

    // Web Adapter (secondary — runs on spawned thread)
    var web: ?adapters.WebAdapter = null;
    var web_thread: ?std.Thread = null;
    
    var discord: ?adapters.DiscordAdapter = null;
    var discord_thread: ?std.Thread = null;

    if (config.web.enabled) {
        var wa = adapters.WebAdapter.init(allocator, &config, &engine);
        wa.adapter().start() catch |err| {
            std.log.err("Failed to start web adapter: {}", .{err});
        };

        if (wa.running) {
            web = wa;
            adapters.registerAdapter(&database.conn, wa.adapter());
            if (std.Thread.spawn(.{}, runAdapter, .{&web.?})) |thread| {
                web_thread = thread;
            } else |err| {
                std.log.err("Failed to spawn web adapter thread: {}", .{err});
                web.?.adapter().stop();
                web = null;
            }
        }
    }

    // Initialize Discord adapter (secondary — runs on spawned thread)
    if (config.discord.enabled) {
        var da = adapters.DiscordAdapter.init(allocator, &config, &engine);
        da.adapter().start() catch |err| {
            std.log.err("Failed to start Discord adapter: {}", .{err});
        };

        if (da.running.load(.Acquire)) {
            discord = da;
            adapters.registerAdapter(&database.conn, da.adapter());
            if (std.Thread.spawn(.{}, runDiscordAdapter, .{&discord.?})) |thread| {
                discord_thread = thread;
            } else |err| {
                std.log.err("Failed to spawn Discord adapter thread: {}", .{err});
                discord.?.adapter().stop();
                discord = null;
            }
        }
    }

    defer {
        // Stop worker pool first (drain queues before DB closes)
        // worker_pool.stop();
        if (web) |*wa| wa.adapter().stop();
        if (web_thread) |t| t.join();
    }

    // Signal handling — stops all adapters
    const handler_fn = struct {
        var cli_ptr: ?*adapters.CliAdapter = null;
        var web_ptr: ?*adapters.WebAdapter = null;

        fn handle(_: c_int) callconv(std.builtin.CallingConvention.c) void {
            if (cli_ptr) |c| c.running = false;
            if (web_ptr) |w| w.running = false;
        }
    };
    handler_fn.cli_ptr = &cli;
    if (web) |*wa| handler_fn.web_ptr = wa;

    const act = std.posix.Sigaction{
        .handler = .{ .handler = handler_fn.handle },
        .mask = std.posix.sigemptyset(),
        .flags = 0,
    };
    std.posix.sigaction(std.posix.SIG.INT, &act, null);
    std.posix.sigaction(std.posix.SIG.TERM, &act, null);

    // Log registered adapters
    const registered = adapters.listRegisteredAdapters(allocator, &database.conn) catch &.{};
    for (registered) |a| {
        std.log.info("Adapter: {s} ({s}) v{s}", .{ a.name, a.display_name, a.version });
    }

    std.log.info("Daemon ready", .{});

    // Run CLI adapter on main thread (blocks until stopped)
    cli_adapter.run();
}

fn runAdapter(wa: *adapters.WebAdapter) void {
    wa.adapter().run();
}

fn runDiscordAdapter(da: *adapters.DiscordAdapter) void {
    da.adapter().run();
}
