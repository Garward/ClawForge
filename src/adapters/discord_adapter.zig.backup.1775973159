const std = @import("std");
const common = @import("common");
const core = @import("core");
const adapter_mod = @import("adapter.zig");

pub const DiscordAdapter = struct {
    allocator: std.mem.Allocator,
    config: *const common.Config,
    engine: *core.Engine,
    token: []const u8,
    running: std.atomic.Value(bool),
    thread_handle: ?std.Thread,
    client: std.http.Client,
    gateway_url: []const u8,
    session_id: ?[]const u8,
    last_sequence: ?u64,
    heartbeat_interval: u32,
    heartbeat_thread: ?std.Thread,
    
    const Self = @This();
    
    pub fn init(allocator: std.mem.Allocator, config: *const common.Config, engine: *core.Engine) !Self {
        // Get Discord token from environment or config
        const token = std.process.getEnvVarOwned(allocator, "DISCORD_TOKEN") catch |err| switch (err) {
            error.EnvironmentVariableNotFound => {
                std.log.err("DISCORD_TOKEN environment variable not set", .{});
                return error.MissingToken;
            },
            else => return err,
        };
        
        // Initialize HTTP client
        const client = std.http.Client{ .allocator = allocator };
        
        // This is a simplified init - we'll get gateway URL when we connect
        const gateway_url = try allocator.dupe(u8, "wss://gateway.discord.gg/?v=10&encoding=json");
        
        return Self{
            .allocator = allocator,
            .config = config,
            .engine = engine,
            .token = token,
            .running = std.atomic.Value(bool).init(false),
            .thread_handle = null,
            .client = client,
            .gateway_url = gateway_url,
            .session_id = null,
            .last_sequence = null,
            .heartbeat_interval = 45000, // 45 seconds default
            .heartbeat_thread = null,
        };
    }
    
    pub fn deinit(self: *Self) void {
        self.stop();
        
        if (self.session_id) |id| {
            self.allocator.free(id);
        }
        self.allocator.free(self.gateway_url);
        self.allocator.free(self.token);
        self.client.deinit();
    }
    
    pub fn adapter(self: *Self) adapter_mod.Adapter {
        return adapter_mod.Adapter.init(self, .{
            .start = adapterStart,
            .stop = adapterStop,
            .send_message = adapterSendMessage,
            .get_status = adapterGetStatus,
        });
    }
    
    pub fn start(self: *Self) !void {
        if (self.running.load(.acquire)) {
            std.log.warn("Discord adapter already running", .{});
            return;
        }
        
        std.log.info("Starting Discord adapter...", .{});
        self.running.store(true, .release);
        
        // Start the main Discord connection thread
        self.thread_handle = try std.Thread.spawn(.{}, runDiscordBot, .{self});
        
        std.log.info("Discord adapter started successfully", .{});
    }
    
    pub fn stop(self: *Self) void {
        if (!self.running.load(.acquire)) {
            return;
        }
        
        std.log.info("Stopping Discord adapter...", .{});
        self.running.store(false, .release);
        
        // Stop heartbeat thread
        if (self.heartbeat_thread) |thread| {
            thread.join();
            self.heartbeat_thread = null;
        }
        
        // Stop main thread
        if (self.thread_handle) |thread| {
            thread.join();
            self.thread_handle = null;
        }
        
        std.log.info("Discord adapter stopped", .{});
    }
    
    pub fn sendMessage(self: *Self, channel_id: []const u8, content: []const u8) !void {
        // Create Discord message payload
        var payload = std.ArrayList(u8).init(self.allocator);
        defer payload.deinit();
        
        try std.json.stringify(.{ .content = content }, .{}, payload.writer());
        
        // Send via Discord API
        const url = try std.fmt.allocPrint(self.allocator, "https://discord.com/api/v10/channels/{s}/messages", .{channel_id});
        defer self.allocator.free(url);
        
        var headers = std.http.Headers.init(self.allocator);
        defer headers.deinit();
        
        const auth_header = try std.fmt.allocPrint(self.allocator, "Bot {s}", .{self.token});
        defer self.allocator.free(auth_header);
        
        try headers.append("Authorization", auth_header);
        try headers.append("Content-Type", "application/json");
        
        const uri = try std.Uri.parse(url);
        var request = try self.client.open(.POST, uri, headers, .{});
        defer request.deinit();
        
        request.transfer_encoding = .{ .content_length = payload.items.len };
        try request.send();
        try request.writeAll(payload.items);
        try request.finish();
        
        const response = try request.wait();
        if (response.status.class() != .success) {
            std.log.err("Failed to send Discord message: HTTP {}", .{response.status});
            return error.DiscordApiError;
        }
    }
    
    fn runDiscordBot(self: *Self) !void {
        std.log.info("Discord bot thread started", .{});
        
        while (self.running.load(.acquire)) {
            self.connectToGateway() catch |err| {
                std.log.err("Discord gateway connection failed: {}", .{err});
                std.time.sleep(5 * std.time.ns_per_s); // Wait 5 seconds before retry
                continue;
            };
        }
        
        std.log.info("Discord bot thread stopping", .{});
    }
    
    fn connectToGateway(self: *Self) !void {
        // This is a simplified implementation
        // In a full implementation, we would:
        // 1. Connect to Discord WebSocket gateway
        // 2. Perform handshake with IDENTIFY payload
        // 3. Start heartbeat thread
        // 4. Listen for messages and events
        // 5. Process MESSAGE_CREATE events and call engine
        
        std.log.info("Connecting to Discord gateway...", .{});
        
        // For now, we'll simulate the connection and message handling
        // In a real implementation, this would use WebSocket connections
        
        while (self.running.load(.acquire)) {
            // Simulate message processing
            std.time.sleep(1 * std.time.ns_per_s);
            
            // Here we would:
            // 1. Receive Discord MESSAGE_CREATE events
            // 2. Extract message content and channel info
            // 3. Call self.processDiscordMessage(message)
        }
    }
    
    fn processDiscordMessage(self: *Self, message_data: []const u8) !void {
        // Parse Discord message JSON
        var parsed = std.json.parseFromSlice(std.json.Value, self.allocator, message_data, .{}) catch |err| {
            std.log.err("Failed to parse Discord message: {}", .{err});
            return;
        };
        defer parsed.deinit();
        
        const message_obj = parsed.value.object;
        const content = message_obj.get("content").?.string;
        const channel_id = message_obj.get("channel_id").?.string;
        const author = message_obj.get("author").?.object;
        const username = author.get("username").?.string;
        const user_id = author.get("id").?.string;
        
        // Skip bot messages
        if (author.get("bot")) |bot_field| {
            if (bot_field.bool) return;
        }
        
        std.log.info("Processing Discord message from {s}: {s}", .{ username, content });
        
        // Create ClawForge message
        var cf_message = core.Message{
            .id = try std.fmt.allocPrint(self.allocator, "discord_{s}_{}", .{ channel_id, std.time.timestamp() }),
            .content = try self.allocator.dupe(u8, content),
            .user_id = try self.allocator.dupe(u8, user_id),
            .username = try self.allocator.dupe(u8, username),
            .timestamp = std.time.timestamp(),
            .metadata = std.StringHashMap([]const u8).init(self.allocator),
        };
        defer {
            self.allocator.free(cf_message.id);
            self.allocator.free(cf_message.content);
            self.allocator.free(cf_message.user_id);
            self.allocator.free(cf_message.username);
            cf_message.metadata.deinit();
        }
        
        // Add Discord-specific metadata
        try cf_message.metadata.put("platform", "discord");
        try cf_message.metadata.put("channel_id", channel_id);
        
        // Process through ClawForge engine
        var response = self.engine.processMessage(&cf_message) catch |err| {
            std.log.err("Engine processing failed: {}", .{err});
            return;
        };
        defer response.deinit();
        
        // Send response back to Discord
        if (response.content.len > 0) {
            self.sendMessage(channel_id, response.content) catch |err| {
                std.log.err("Failed to send Discord response: {}", .{err});
            };
        }
    }
};

// Implement the Adapter interface
// Adapter wrapper functions
fn adapterStart(ctx: *anyopaque) !void {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ctx));
    try self.start();
}

fn adapterStop(ctx: *anyopaque) void {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ctx));
    self.stop();
}

fn adapterSendMessage(ctx: *anyopaque, message: []const u8) !void {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ctx));
    // Discord messages need channel context - for now just log
    _ = self;
    std.log.info("Discord message: {s}", .{message});
}

fn adapterGetStatus(ctx: *anyopaque) adapter_mod.AdapterStatus {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ctx));
    return adapter_mod.AdapterStatus{
        .name = "discord",
        .running = self.running.load(.Acquire),
        .connections = if (self.running.load(.Acquire)) 1 else 0,
        .messages_sent = 0,
        .messages_received = 0,
    };
}

pub fn create(allocator: std.mem.Allocator, config: *const common.Config, engine: *core.Engine) !adapter_mod.Adapter {
    var discord_adapter = try DiscordAdapter.init(allocator, config, engine);
    
    return adapter_mod.Adapter{
        .ptr = &discord_adapter,
        .vtable = &.{
            .start = startImpl,
            .stop = stopImpl,
            .deinit = deinitImpl,
        },
    };
}

fn startImpl(ptr: *anyopaque) !void {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ptr));
    return self.start();
}

fn stopImpl(ptr: *anyopaque) void {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ptr));
    self.stop();
}

fn deinitImpl(ptr: *anyopaque) void {
    const self: *DiscordAdapter = @ptrCast(@alignCast(ptr));
    self.deinit();
}