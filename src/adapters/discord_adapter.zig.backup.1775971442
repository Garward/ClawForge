const std = @import("std");
const Allocator = std.mem.Allocator;
const ArrayList = std.ArrayList;
const HashMap = std.HashMap;
const Thread = std.Thread;
const json = std.json;
const net = std.net;
const http = std.http;
const Adapter = @import("adapter.zig").Adapter;
const Engine = @import("../engine.zig").Engine;
const Message = @import("../types.zig").Message;
const logger = @import("../logger.zig");

pub const DiscordAdapter = struct {
    allocator: Allocator,
    engine: *Engine,
    token: []const u8,
    thread: ?Thread,
    running: bool,
    client: ?http.Client,
    gateway_url: ?[]const u8,
    session_id: ?[]const u8,
    last_sequence: ?u32,
    heartbeat_interval: ?u32,
    
    const Self = @This();
    
    pub fn init(allocator: Allocator, engine: *Engine, config: anytype) !*Self {
        const self = try allocator.create(Self);
        
        // Get Discord token from config
        const token = config.get("discord_token") orelse return error.MissingDiscordToken;
        
        self.* = Self{
            .allocator = allocator,
            .engine = engine,
            .token = try allocator.dupe(u8, token),
            .thread = null,
            .running = false,
            .client = null,
            .gateway_url = null,
            .session_id = null,
            .last_sequence = null,
            .heartbeat_interval = null,
        };
        
        logger.info("Discord adapter initialized");
        return self;
    }
    
    pub fn deinit(self: *Self) void {
        self.stop();
        if (self.gateway_url) |url| {
            self.allocator.free(url);
        }
        if (self.session_id) |id| {
            self.allocator.free(id);
        }
        if (self.client) |*client| {
            client.deinit();
        }
        self.allocator.free(self.token);
        self.allocator.destroy(self);
    }
    
    pub fn start(self: *Self) !void {
        if (self.running) return;
        
        logger.info("Starting Discord adapter...");
        self.running = true;
        
        // Initialize HTTP client
        self.client = http.Client{ .allocator = self.allocator };
        
        // Get gateway URL
        try self.getGatewayUrl();
        
        // Start gateway connection in separate thread
        self.thread = try Thread.spawn(.{}, gatewayThread, .{self});
        
        logger.info("Discord adapter started");
    }
    
    pub fn stop(self: *Self) void {
        if (!self.running) return;
        
        logger.info("Stopping Discord adapter...");
        self.running = false;
        
        if (self.thread) |thread| {
            thread.join();
            self.thread = null;
        }
        
        logger.info("Discord adapter stopped");
    }
    
    pub fn send_message(self: *Self, message: []const u8, context: anytype) !void {
        // Extract channel_id from context
        const channel_id = context.get("channel_id") orelse return error.MissingChannelId;
        
        // Send message to Discord channel
        try self.sendDiscordMessage(channel_id, message);
    }
    
    pub fn handle_event(self: *Self, event_type: []const u8, data: anytype) !void {
        // Handle Discord-specific events
        if (std.mem.eql(u8, event_type, "message")) {
            try self.handleDiscordMessage(data);
        }
    }
    
    // Discord API Methods
    
    fn getGatewayUrl(self: *Self) !void {
        var client = self.client.?;
        
        // Discord API endpoint for gateway
        const url = "https://discord.com/api/v10/gateway/bot";
        
        var headers = http.Headers{ .allocator = self.allocator };
        defer headers.deinit();
        
        // Add authorization header
        var auth_header = try std.fmt.allocPrint(self.allocator, "Bot {s}", .{self.token});
        defer self.allocator.free(auth_header);
        try headers.append("Authorization", auth_header);
        try headers.append("Content-Type", "application/json");
        
        var request = try client.request(.GET, try std.Uri.parse(url), headers, .{});
        defer request.deinit();
        
        try request.start();
        try request.wait();
        
        if (request.response.status != .ok) {
            logger.err("Failed to get gateway URL: {}", .{request.response.status});
            return error.GatewayRequestFailed;
        }
        
        // Read response body
        var response_body = ArrayList(u8).init(self.allocator);
        defer response_body.deinit();
        
        const max_size = 1024 * 1024; // 1MB max
        try request.reader().readAllArrayList(&response_body, max_size);
        
        // Parse JSON response
        const parsed = try json.parseFromSlice(json.Value, self.allocator, response_body.items, .{});
        defer parsed.deinit();
        
        const gateway_obj = parsed.value.object.get("url").?.string;
        self.gateway_url = try self.allocator.dupe(u8, gateway_obj);
        
        logger.info("Got Discord gateway URL: {s}", .{self.gateway_url.?});
    }
    
    fn sendDiscordMessage(self: *Self, channel_id: []const u8, content: []const u8) !void {
        var client = self.client.?;
        
        // Build Discord API URL
        var url = try std.fmt.allocPrint(self.allocator, "https://discord.com/api/v10/channels/{s}/messages", .{channel_id});
        defer self.allocator.free(url);
        
        var headers = http.Headers{ .allocator = self.allocator };
        defer headers.deinit();
        
        // Add authorization header
        var auth_header = try std.fmt.allocPrint(self.allocator, "Bot {s}", .{self.token});
        defer self.allocator.free(auth_header);
        try headers.append("Authorization", auth_header);
        try headers.append("Content-Type", "application/json");
        
        // Build JSON payload
        var payload = try std.fmt.allocPrint(self.allocator, "{{\"content\": \"{s}\"}}", .{content});
        defer self.allocator.free(payload);
        
        var request = try client.request(.POST, try std.Uri.parse(url), headers, .{});
        defer request.deinit();
        
        request.transfer_encoding = .{ .content_length = payload.len };
        try request.start();
        
        // Send payload
        try request.writeAll(payload);
        try request.finish();
        try request.wait();
        
        if (request.response.status != .ok) {
            logger.err("Failed to send Discord message: {}", .{request.response.status});
        } else {
            logger.info("Sent Discord message to channel {s}", .{channel_id});
        }
    }
    
    fn handleDiscordMessage(self: *Self, message_data: anytype) !void {
        // Extract message content and metadata
        const content = message_data.get("content") orelse return;
        const author = message_data.get("author") orelse return;
        const channel_id = message_data.get("channel_id") orelse return;
        const author_id = author.get("id") orelse return;
        const author_name = author.get("username") orelse return;
        
        // Skip bot messages
        if (author.get("bot")) |is_bot| {
            if (is_bot) return;
        }
        
        // Check if message mentions the bot or is in DM
        const mentions_bot = self.checkMentions(message_data);
        const is_dm = std.mem.eql(u8, message_data.get("guild_id") orelse "", "");
        
        if (!mentions_bot and !is_dm) return;
        
        // Create ClawForge message
        var clawforge_message = Message{
            .content = content,
            .author = author_name,
            .timestamp = std.time.timestamp(),
            .metadata = .{},
        };
        
        // Add Discord-specific metadata
        clawforge_message.metadata.put("platform", "discord") catch {};
        clawforge_message.metadata.put("channel_id", channel_id) catch {};
        clawforge_message.metadata.put("author_id", author_id) catch {};
        
        // Process through ClawForge engine
        const response = try self.engine.process(clawforge_message);
        
        // Send response back to Discord
        const context = std.StringHashMap([]const u8).init(self.allocator);
        defer context.deinit();
        try context.put("channel_id", channel_id);
        
        try self.send_message(response.content, context);
    }
    
    fn checkMentions(self: *Self, message_data: anytype) bool {
        // Check if the bot is mentioned in the message
        if (message_data.get("mentions")) |mentions| {
            // In a real implementation, we'd check if our bot's user ID is in mentions
            // For now, assume any message with @ mentions the bot
            return true;
        }
        return false;
    }
    
    // Gateway WebSocket handling
    fn gatewayThread(self: *Self) !void {
        logger.info("Starting Discord gateway connection...");
        
        while (self.running) {
            // In a full implementation, this would:
            // 1. Connect to Discord gateway WebSocket
            // 2. Send identify payload
            // 3. Handle heartbeat
            // 4. Process incoming events
            // 5. Reconnect on disconnection
            
            // For now, just sleep and check running status
            std.time.sleep(1000 * 1000 * 1000); // 1 second
        }
        
        logger.info("Discord gateway thread exiting");
    }
};

// Adapter interface implementation
pub fn create(allocator: Allocator, engine: *Engine, config: anytype) !*Adapter {
    const discord_adapter = try DiscordAdapter.init(allocator, engine, config);
    
    const adapter = try allocator.create(Adapter);
    adapter.* = Adapter{
        .ptr = discord_adapter,
        .vtable = &.{
            .start = @ptrCast(&DiscordAdapter.start),
            .stop = @ptrCast(&DiscordAdapter.stop),
            .send_message = @ptrCast(&DiscordAdapter.send_message),
            .handle_event = @ptrCast(&DiscordAdapter.handle_event),
            .deinit = @ptrCast(&DiscordAdapter.deinit),
        },
    };
    
    return adapter;
}