const std = @import("std");
const json = std.json;
const Allocator = std.mem.Allocator;
const ArrayList = std.ArrayList;
const HashMap = std.HashMap;

const ToolResult = @import("../core.zig").ToolResult;
const pythonRunner = @import("../python_runner.zig");

pub const ResearchTool = struct {
    allocator: Allocator,
    
    pub fn init(allocator: Allocator) ResearchTool {
        return ResearchTool{
            .allocator = allocator,
        };
    }
    
    pub fn deinit(self: *ResearchTool) void {
        _ = self;
    }
    
    pub fn getName(self: *const ResearchTool) []const u8 {
        _ = self;
        return "research_tool";
    }
    
    pub fn getDescription(self: *const ResearchTool) []const u8 {
        _ = self;
        return "Comprehensive web research tool. Search the web, Wikipedia, news, or academic sources for information. Privacy-focused using DuckDuckGo (no API keys needed). Use 'general' for mixed results, 'wikipedia' for encyclopedic info, 'news' for current events, 'academic' for papers/research.";
    }
    
    pub fn getInputSchema(self: *const ResearchTool) []const u8 {
        _ = self;
        return 
            \\{
            \\  "type": "object",
            \\  "properties": {
            \\    "query": {
            \\      "type": "string",
            \\      "description": "Search term or question to research"
            \\    },
            \\    "search_type": {
            \\      "type": "string",
            \\      "description": "Type of search: 'general', 'wikipedia', 'news', or 'academic'",
            \\      "enum": ["general", "wikipedia", "news", "academic"],
            \\      "default": "general"
            \\    },
            \\    "max_results": {
            \\      "type": "integer", 
            \\      "description": "Maximum number of results to return",
            \\      "default": 8,
            \\      "minimum": 1,
            \\      "maximum": 20
            \\    },
            \\    "include_wikipedia": {
            \\      "type": "boolean",
            \\      "description": "Include Wikipedia results in general searches", 
            \\      "default": true
            \\    },
            \\    "include_news": {
            \\      "type": "boolean",
            \\      "description": "Include news results in general searches",
            \\      "default": false
            \\    }
            \\  },
            \\  "required": ["query"]
            \\}
        ;
    }
    
    pub fn execute(self: *ResearchTool, input: []const u8) !ToolResult {
        const script_path = "/home/garward/Scripts/Tools/ClawForge/tools/research_tool.py";
        return pythonRunner.runPythonTool(self.allocator, script_path, input);
    }
    
    pub fn requiresConfirmation(self: *const ResearchTool) bool {
        _ = self;
        return false;
    }
};